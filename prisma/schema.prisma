generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  ADMIN
  TENANT
  MAINTENANCE
  MANAGEMENT
}

enum TenantStatus {
  ACTIVE
  PENDING
  INACTIVE
  DELINQUENT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  SCHEDULED
  COMPLETED
  CLOSED
}

enum PaymentMethod {
  CREDIT_CARD
  ACH
  CHECK
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  MAINTENANCE
  OCCUPIED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole @default(TENANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant?
  sentMessages      Message[]           @relation("SentMessages")
  ticketComments    TicketComment[]
  createdTickets    MaintenanceTicket[] @relation("CreatedTickets")
  updatedTickets    MaintenanceTicket[] @relation("UpdatedTickets")

  @@map("users")
}

model Tenant {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitId      String?
  unit        Unit?        @relation(fields: [unitId], references: [id])
  leaseStart  DateTime?
  leaseEnd    DateTime?
  rentAmount  Float        @default(0)
  balance     Float        @default(0)
  status      TenantStatus @default(PENDING)
  moveInDate  DateTime?
  moveOutDate DateTime?
  inviteCode  String?      @unique
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tickets       MaintenanceTicket[]
  payments      Payment[]
  leaseRenewals LeaseRenewal[]
  parkingSpots  ParkingSpot[]

  // Insurance
  insuranceProvider String?
  insurancePolicyNo String?
  insuranceExpiry   DateTime?
  autopayEnabled    Boolean      @default(false)

  @@map("tenants")
}

model Unit {
  id            String     @id @default(cuid())
  number        String     @unique
  floor         Int        @default(1)
  bedrooms      Int        @default(1)
  bathrooms     Int        @default(1)
  sqft          Int        @default(0)
  rent          Float      @default(0)
  status        UnitStatus @default(AVAILABLE)
  availableDate DateTime?
  features      String[]   @default([])
  propertyId    String?
  property      Property?  @relation(fields: [propertyId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenants       Tenant[]

  @@map("units")
}

model Property {
  id                  String   @id @default(cuid())
  name                String
  address             String
  city                String
  totalUnits          Int      @default(0)
  paymentDueDay       Int      @default(1)
  lateFeeGraceDays    Int      @default(5)
  lateFeeAmount       Float    @default(50)
  acceptCreditCard    Boolean  @default(true)
  acceptACH           Boolean  @default(true)
  bankName            String   @default("")
  bankAccountHolder   String   @default("")
  bankRoutingNumber   String   @default("")
  bankAccountNumber   String   @default("")
  bankAccountType     String   @default("checking")
  zelleEmail          String   @default("")
  paymentInstructions String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  units               Unit[]
  announcements       Announcement[]

  @@map("properties")
}

model MaintenanceTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique
  title           String
  description     String
  category        String
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  location        String?
  scheduledDate   DateTime?
  tenantId        String?
  tenant          Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entryPermission String?
  photos          String?
  createdById     String?
  createdBy       User?          @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: SetNull)
  statusChangedById String?
  statusChangedBy   User?        @relation("UpdatedTickets", fields: [statusChangedById], references: [id], onDelete: SetNull)
  statusChangedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  comments        TicketComment[]

  @@map("maintenance_tickets")
}

model TicketComment {
  id        String            @id @default(cuid())
  message   String
  authorId  String
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  ticketId  String
  ticket    MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@map("ticket_comments")
}

model Payment {
  id                 String        @id @default(cuid())
  amount             Float
  description        String
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  confirmationNumber String?
  tenantId           String
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now())

  @@map("payments")
}

model LeaseRenewal {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentLeaseEnd DateTime
  newLeaseStart   DateTime
  newLeaseEnd     DateTime
  currentRent     Float
  proposedRent    Float
  status          String    @default("pending")
  offeredDate     DateTime?
  respondedDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("lease_renewals")
}

model Announcement {
  id         String    @id @default(cuid())
  title      String
  message    String
  priority   String    @default("normal")
  author     String
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  createdAt  DateTime  @default(now())

  @@map("announcements")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("messages")
}

model Conversation {
  id           String   @id @default(cuid())
  subject      String
  participants String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("conversations")
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  fileUrl     String?
  size        String?
  tenantId    String?
  content     String?
  signToken   String?  @unique
  signedAt    DateTime?
  signedName  String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())

  @@map("documents")
}

model NotificationLog {
  id           String   @id @default(cuid())
  templateName String
  recipient    String
  email        String
  subject      String
  status       String   @default("pending")
  channel      String   @default("email")
  createdAt    DateTime @default(now())

  @@map("notification_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String?
  details   String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Checklist {
  id         String   @id @default(cuid())
  type       String
  unitId     String?
  tenantId   String?
  tenantName String?
  unitNumber String?
  items      String   @default("[]")
  notes      String?
  completedAt DateTime?
  completedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("checklists")
}

model RentalApplication {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  currentAddress  String?
  employer        String?
  income          Float?
  moveInDate      String?
  desiredUnit     String?
  message         String?
  status          String   @default("pending")
  reviewedBy      String?
  reviewNotes     String?

  // Background check fields
  dateOfBirth     String?
  ssnLast4        String?
  consentGiven    Boolean  @default(false)
  screeningStatus String?  @default("not_started")
  screeningResult String?
  screeningDate   DateTime?
  creditScore     Int?
  criminalClear   Boolean?
  evictionClear   Boolean?
  identityVerified Boolean?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("rental_applications")
}

model Amenity {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  capacity    Int      @default(0)
  requiresBooking Boolean @default(true)
  availableFrom   String   @default("08:00")
  availableTo     String   @default("22:00")
  rules       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    AmenityBooking[]

  @@map("amenities")
}

model AmenityBooking {
  id          String   @id @default(cuid())
  amenityId   String
  amenity     Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenantName  String
  unit        String?
  date        String
  startTime   String
  endTime     String
  notes       String?
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  @@map("amenity_bookings")
}

model Package {
  id          String   @id @default(cuid())
  carrier     String
  trackingNo  String?
  tenantId    String?
  tenantName  String
  unit        String
  description String?
  status      String   @default("received")
  receivedBy  String?
  pickedUpAt  DateTime?
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("packages")
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  company     String?
  email       String?
  phone       String?
  specialty   String
  rating      Int      @default(0)
  notes       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("vendors")
}

model ParkingSpot {
  id          String   @id @default(cuid())
  spotNumber  String   @unique
  type        String   @default("standard")
  level       String?
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  tenantName  String?
  unit        String?
  monthlyFee  Float    @default(0)
  status      String   @default("available")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("parking_spots")
}

model Survey {
  id          String   @id @default(cuid())
  title       String
  description String?
  questions   String   @default("[]")
  status      String   @default("active")
  createdBy   String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  responses   SurveyResponse[]

  @@map("surveys")
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenantName  String?
  unit        String?
  answers     String   @default("[]")
  rating      Int?
  comment     String?
  createdAt   DateTime @default(now())

  @@map("survey_responses")
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  vendor      String?
  date        DateTime
  recurring   Boolean  @default(false)
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model CommunityPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  authorId  String?
  authorName String
  unit      String?
  pinned    Boolean  @default(false)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("community_posts")
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String
  content     String
  variables   String   @default("[]")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("document_templates")
}
